{
  "name": "galwriter-ai",
  "private": true,
  "version": "1.2.5",
  "type": "module",
  "description": "交互式剧本编辑器 - GalWriter AI",
  "author": "GalWriter",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck && npm run lint:eslint && npm run format:check",
    "lint:eslint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"*.{json,md,html,ts,js}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"*.{json,md,html,ts,js}\"",
    "tauri": "tauri"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "@tailwindcss/vite": "^4.1.14",
    "@tauri-apps/api": "^2.11.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@xyflow/react": "^12.10.2",
    "idb": "^8.0.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "uuid": "^14.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@tauri-apps/cli": "^2.0.0",
    "@types/jszip": "^3.4.0",
    "@types/node": "^22.14.0",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^16.2.0",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.33.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
