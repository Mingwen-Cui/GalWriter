{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "GalWriter AI",
  "version": "1.2.5",
  "identifier": "com.galwriter.ai",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "GalWriter AI 多结局AI剧本生成器",
        "width": 1000,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Mingwen Cui",
    "copyright": "Copyright © 2026 Mingwen Cui (mingwencui.com). All Rights Reserved.",
    "category": "DeveloperTool",
    "shortDescription": "多结局AI剧本生成器",
    "longDescription": "由AI驱动多结局剧本创作工具。",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "zh-CN"
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
